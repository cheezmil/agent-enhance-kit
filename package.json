{
  "name": "agent-enhance-kit",
  "version": "0.6.0",
  "description": "AI Agent infrastructure - multi-provider search, MCP management, and more",
  "private": true,
  "bin": {
    "aek": "./packages/aek-websearch/bin/aek"
  },
  "scripts": {
    "build": "cd packages/aek-websearch && go build -o bin/aek ./cmd/aek/",
    "build:all": "npm run build",
    "dev": "cd packages/aek-websearch && go run ./cmd/aek/ serve",
    "test": "cd packages/aek-websearch && go test ./...",
    "install:global": "npm install -g .",
    "postinstall": "node packages/aek-websearch/scripts/postinstall.mjs"
  },
  "keywords": [
    "ai",
    "agent",
    "search",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.17.0"
  }
}
